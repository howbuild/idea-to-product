{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.py\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \"${CLAUDE_PLUGIN_ROOT}/hooks/user-prompt-scope-router.py\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \"${CLAUDE_PLUGIN_ROOT}/hooks/feature-drift-gate.py\""
          },
          {
            "type": "command",
            "command": "py -3 \"${CLAUDE_PLUGIN_ROOT}/hooks/reference-gap-review.py\""
          },
          {
            "type": "command",
            "command": "py -3 \"${CLAUDE_PLUGIN_ROOT}/hooks/completeness-gate.py\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \"${CLAUDE_PLUGIN_ROOT}/hooks/wireframe-change-review.py\""
          },
          {
            "type": "command",
            "command": "py -3 \"${CLAUDE_PLUGIN_ROOT}/hooks/policy-consistency-review.py\""
          },
          {
            "type": "command",
            "command": "py -3 \"${CLAUDE_PLUGIN_ROOT}/hooks/measurement-coverage-review.py\""
          },
          {
            "type": "command",
            "command": "py -3 \"${CLAUDE_PLUGIN_ROOT}/hooks/source-quality-review.py\""
          },
          {
            "type": "command",
            "command": "py -3 \"${CLAUDE_PLUGIN_ROOT}/hooks/copy-risk-review.py\""
          },
          {
            "type": "command",
            "command": "py -3 \"${CLAUDE_PLUGIN_ROOT}/hooks/cross-document-consistency-review.py\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \"${CLAUDE_PLUGIN_ROOT}/hooks/human-writing-final-pass.py\""
          }
        ]
      }
    ]
  }
}
